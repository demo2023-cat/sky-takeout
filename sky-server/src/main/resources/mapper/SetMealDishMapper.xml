<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.SetMealDishMapper">
    <insert id="insertBatch">
        <foreach collection="setMealDishes" separator=";" item="setMealDish">
            insert into setmeal_dish (setmeal_id,dish_id,name,price,copies) values (#{setMealDish.setmealId},#{setMealDish.dishId},#{setMealDish.name},#{setMealDish.price},#{setMealDish.copies})
        </foreach>
    </insert>
</mapper>
